val {*} = import(
	'slug.std',
  'slug.channel',
)
val log = import("slug.log").logger(moduleName())
val jsonrpc = import("slug.jsonrpc")
val stdin = import("slug.io.stdin")
val runtime = import("slug.acp.runtime")
val stub = import("slug.acp.stub")

val newClient = fn() {
  {
    nextId: 1,
    sessionId: nil,
  }
}

val allocId = fn(client) {
  {
    id: client.nextId,
    client: put(client, :nextId, client.nextId + 1),
  }
}

val recvOrNil = fn(ch) {
  match recv(ch) {
    Empty{} => nil
    Full{value} => value
  }
}

val stdioTransport = fn() {
  {
    read: fn() {
      stdin.readLine() /> log.cInfo("IN:  {}")
    },
    write: fn(@str line) {
      println(line) /> log.cInfo("OUT:  {}")
    },
    close: fn() { nil },
  }
}

val stubTransport = fn() {
  val clientToServer = chan(64)
  val serverToClient = chan(64)

  val serverIo = {
    read: fn() {
      recvOrNil(clientToServer) /> log.cInfo("IN:  {}")
    },
    write: fn(@str line) {
      send(serverToClient, log.cInfo(line, "OUT:  {}"))
    },
  }

  spawn {
    runtime.run(stub.handlers(), serverIo)
    close(serverToClient)
  }

  {
    read: fn() {
      recvOrNil(serverToClient)
    },
    write: fn(@str line) {
      send(clientToServer, line)
    },
    close: fn() {
      close(clientToServer)
    },
  }
}

val send = fn(transport, message) {
  transport.write(jsonrpc.encode(message))
}

val readMessage = fn(transport) {
  val raw = transport.read()
  match raw {
    nil => nil
    _ => jsonrpc.parse(raw)
  }
}

val sendRequest = fn(transport, client, method, params = nil) {
  val alloc = allocId(client)
  val id = alloc.id
  val nextClient = alloc.client

  send(transport, jsonrpc.request(id, method, params))

  {
    id: id,
    client: nextClient,
  }
}

val renderToolContent = fn(content) {
  match content {
    [] => nil
    [part, ...rest] => {
      match part.type {
        "content" => match part.content.type {
          "text" => println(part.content.text)
          _ => nil
        }
        _ => nil
      }
      renderToolContent(rest)
    }
  }
}

val renderUpdate = fn(update) {
  match update.sessionUpdate {
    "agent_message_chunk" => {
      match update.content.type {
        "text" => println(update.content.text)
        _ => println("[assistant chunk]")
      }
    }

    "tool_call" => {
      println("[tool] " + update.title)
    }

    "tool_call_update" => {
      println("[tool:" + update.status + "] " + update.toolCallId)
      match update.content {
        nil => nil
        c => renderToolContent(c)
      }
    }

    other => {
      println("[update] " + other)
    }
  }
}

val renderResult = fn(result) {
  match result.content {
    nil => nil
    xs => renderFinalContent(xs)
  }

  match result.stopReason {
    nil => nil
    s => println("[" + s + "]")
  }
}

val renderFinalContent = fn(content) {
  match content {
    [] => nil
    [part, ...rest] => {
      match part.type {
        "text" => println(part.text)
        _ => nil
      }
      renderFinalContent(rest)
    }
  }
}

val awaitResponse = fn(transport, requestId) {
  val loop = fn() {
    match readMessage(transport) {
      nil => nil

      msg => {
        if (jsonrpc.isResponse(msg)) {
          if (msg.id == requestId) {
            match msg.error {
              nil => renderResult(msg.result)
              e => println("[error] " + e.message)
            }
            nil
          } else {
            recur()
          }
        } else {
          match msg.method {
            "session/update" => {
              renderUpdate(msg.params.update)
              recur()
            }
            _ => recur()
          }
        }
      }
    }
  }

  loop()
}

val promptLoop = fn(transport, client) {
  println("")
  println("Knuckles CLI ready. Enter a prompt, or blank line to exit.")

  val loop = fn(clientState) {
    print("> ")
    match stdin.readLine() {
      nil => nil
      "" => nil

      line => {
        val sent = sendRequest(transport, clientState, "session/prompt", {
          sessionId: clientState.sessionId,
          prompt: [
            {
              type: "text",
              text: line,
            },
          ],
        })

        awaitResponse(transport, sent.id)
        recur(sent.client)
      }
    }
  }

  loop(client)
}

@main
val main = fn() {
  val args = argm()
  val options = args.options
  val useStub = match [options.stub, options.transport] {
    [true, ...] => true
    [_, "stub"] => true
    _ => false
  }

  val transport = match useStub {
    true => stubTransport()
    false => stdioTransport()
  }
  defer {
    transport.close()
  }

  var client = newClient()

  val initSent = sendRequest(transport, client, "initialize", {
    protocolVersion: 1,
    clientCapabilities: {
      fs: {
        readTextFile: true,
        writeTextFile: true,
      },
      terminal: false,
    },
    clientInfo: {
      name: "Knuckles CLI",
      version: "0.1.0",
      title: "Knuckles CLI",
    },
    _meta: {},
  })
  client = initSent.client
  awaitResponse(transport, initSent.id)

  val newSent = sendRequest(transport, client, "session/new", {
    cwd: ".",
    mcpServers: [],
  })
  client = newSent.client

  val captureSession = fn() {
    val loop = fn() {
      match readMessage(transport) {
        nil => client

        msg => {
          if (jsonrpc.isResponse(msg) && msg.id == newSent.id) {
            match msg.error {
              nil => put(client, :sessionId, msg.result.sessionId)
              e => {
                println("[error] " + e.message)
                client
              }
            }
          } else {
            match msg.method {
              "session/update" => {
                renderUpdate(msg.params.update)
                recur()
              }
              _ => recur()
            }
          }
        }
      }
    }

    loop()
  }

  client = captureSession()

  match client.sessionId {
    nil => println("failed to create session")
    _ => promptLoop(transport, client)
  }
}
