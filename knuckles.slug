/**
 * knuckles — Slug coding agent
 *
 * A local coding agent that inspects, understands, and modifies
 * Slug repositories through an iterative tool-use loop backed by
 * a local Ollama model.
 *
 * Usage:
 * ```bash
 * slug run knuckles.slug run    --goal "Add caching to evaluator" --repo .
 * slug run knuckles.slug resume --id a3f9c2d1
 * slug run knuckles.slug list
 * ```
 *
 * Commands:
 * - `run`     start a new agent session
 * - `resume`  resume an existing session by ID
 * - `list`    show all sessions
 * - `show`    print full turn-by-turn history for a session
 * - `issue`   start a session from a GitHub issue
 * - `review`  review a GitHub PR
 *
 * Options:
 * - `-h, --help`      show this screen
 * - `-v, --version`   show version
 * - `--goal`          task description (required for `run`)
 * - `--repo`          repository — local path or owner/repo (default: .)
 * - `--id`            session ID (required for `resume` and `show`)
 * - `--issue`         GitHub issue number (required for `issue`)
 * - `--pr`            GitHub PR number (required for `review`)
 * - `--base`          base branch for PR (default: main)
 * - `--draft`         open PR as draft (default: false)
 * - `--model`         Ollama model name (default: llama3)
 * - `--db`            SQLite database path (default: knuckles.db)
 * - `--test`          command to run after every edit
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
)
val db    = import("slug.io.db")
val sys   = import("slug.sys")
val agent = import("knuckles.agent")
val store = import("knuckles.store")
val { argsWith } = import("slug.cli")

// --- CLI spec ---

val spec = {
  name:    "knuckles",
  version: "0.1.0",
  summary: "Slug coding agent — AI-assisted development for Slug repositories",
  defaults: {
    repo:  ".",
    model: "llama3",
    db:    "knuckles.db",
  },
  types: {
    goal:  "str",
    repo:  "str",
    id:    "str",
    issue: "num",
    pr:    "num",
    base:  "str",
    draft: "bool",
    model: "str",
    db:    "str",
    test:  "str",
    mode:  "str",
  },
  desc: {
    goal:  "task description (required for `run`)",
    repo:  "repository — local path or owner/repo",
    id:    "session ID (required for `resume` and `show`)",
    issue: "GitHub issue number (required for `issue`)",
    pr:    "GitHub PR number (required for `review`)",
    base:  "base branch for PR",
    draft: "open PR as draft",
    model: "Ollama model name",
    db:    "SQLite database path",
    test:  "command to run automatically after every successful edit",
    mode:  "prompt overlay: local | issue | review | report (default: auto)",
  },
  positional: { min: 0, max: 1, name: "command" },
}

// --- session listing ---

val printSessions = fn(sessions) {
  match sessions {
    [] => println("no sessions found.")
    _  => {
      println(fmt("|{:<16s}|{:<8s}|{:<10s}| goal", "id", "turns", "status"))
      println("|" + padRight("", "-", 16) + "|" + padRight("", "-", 8) + "|" + padRight("", "-", 10) + "|" + padRight("", "-", 40))
      sessions /> map(fn(row) {
        val status = match row["done"] { 1 => "done" _ => "active" }
        println(fmt("|{:<16s}|{:<8d}|{:<10s}| {}", row["id"], row["turn"], status, row["goal"]))
      })
    }
  }
}

// --- entrypoint ---

@main
val main = fn(args = argm()) {
  val result = args /> argsWith(spec)

  match result {
    { action: :help }    => { println(result.text); sys.exit(0) }
    { action: :version } => { println(result.text); sys.exit(0) }
    { action: :error }   => {
      result.errors /> map(fn(e) { println(e.msg) })
      sys.exit(1)
    }
    { ok: true, options, positional } => {

      // forward options into cfg so agent/store/tools pick them up
      sys.setEnv("SLUG_CFG_knuckles_db",    options.db)
      sys.setEnv("SLUG_CFG_knuckles_model", options.model)
      match options.test {
        nil => nil
        cmd => sys.setEnv("SLUG_CFG_run_after_edit", cmd)
      }

      val command = match positional {
        []         => "list"
        [cmd, ...] => cmd
      }

      match command {
        "run" => {
          match options.goal {
            nil => {
              println("error: --goal is required for the run command")
              sys.exit(1)
            }
            goal => {
              // auto-detect report mode from goal keywords unless overridden
              val mode = match options.mode {
                nil => match goal /> toLower /> containsAny(["report", "document", "describe", "write a"]) {
                  true  => :report
                  false => :local
                }
                m => sym(m)
              }
              agent.run(goal, options.repo, mode = mode)
            }
          }
        }
        "resume" => {
          match options.id {
            nil => {
              println("error: --id is required for the resume command")
              sys.exit(1)
            }
            id => agent.resume(id, mode = :local)
          }
        }
        "show" => {
          match options.id {
            nil => {
              println("error: --id is required for the show command")
              sys.exit(1)
            }
            id => {
              val conn = store.openDb()
              defer { db.close(conn) }
              match store.loadSession(conn, id) {
                nil => {
                  println(fmt("Session not found: {}", id))
                  sys.exit(1)
                }
                { session: s } => {
                  println(fmt("Session {} (turn {})", id, s.turn))
                  s.history /> map(fn(turn) {
                    val roleLabel = match turn.role {
                      :user      => "user"
                      :assistant => "assistant"
                      _          => label(turn.role)
                    }
                    println(fmt("[{}] {}", roleLabel, turn.content))
                  })
                }
              }
            }
          }
        }
        "list" => {
          val conn = store.openDb()
          defer { db.close(conn) }
          store.listSessions(conn) /> printSessions
        }
        "issue" => {
          match options.issue {
            nil => {
              println("error: --issue is required for the issue command")
              sys.exit(1)
            }
            issueNum => {
              val ghIssue = import("knuckles.github.issue")
              val ghRepo  = import("knuckles.github.repo")

              // resolve repo — local path or clone
              val resolved = ghRepo.resolveRepo(options.repo)

              // fetch issue + comments, build goal
              val issue    = ghIssue.getIssue(resolved.owner, resolved.name, issueNum)
              val comments = ghIssue.getComments(resolved.owner, resolved.name, issueNum)
              val goal     = ghIssue.buildGoal(issue, comments)

              // create session branch
              val branch   = ghRepo.createBranch(resolved.path, issueNum, issue["title"])

              println("▶ Knuckles — issue #" + issueNum + ": " + issue["title"])
              println("  branch: " + branch)
              println("  repo:   " + resolved.path)
              println("")

              // run the agent loop
              val finalSession = agent.run(goal, resolved.path, mode = :issue)

              // push and open PR if session completed successfully
              match finalSession.done && len(finalSession.patches) > 0 {
                false => {
                  println("⚠ Session ended without changes — no PR opened")
                }
                true => {
                  ghRepo.push(resolved.path, branch)
                  val ghPr   = import("knuckles.github.pr")
                  val conn   = store.openDb()
                  defer { db.close(conn) }
                  val sessions = store.listSessions(conn)
                  val sessionId = match sessions {
                    [row, ...] => row["id"]
                    _          => "unknown"
                  }
                  val prTitle = "knuckles: " + issue["title"]
                  val prBody  = ghPr.buildDescription(finalSession, sessionId, issueNum)
                  val prResult = ghPr.openPr(
                    resolved.owner,
                    resolved.name,
                    branch,
                    prTitle,
                    prBody,
                    base  = options.base /> ifNil("main"),
                    draft = options.draft /> ifNil(false),
                  )
                  println("✓ PR opened: " + prResult["html_url"])
                }
              }
            }
          }
        }
        "review" => {
          match options.pr {
            nil => {
              println("error: --pr is required for the review command")
              sys.exit(1)
            }
            prNum => {
              val ghPr   = import("knuckles.github.pr")
              val ghRepo = import("knuckles.github.repo")

              val resolved = ghRepo.resolveRepo(options.repo)
              val pr       = ghPr.getPr(resolved.owner, resolved.name, prNum)
              val diff     = ghPr.getPrDiff(resolved.owner, resolved.name, prNum)
              val comments = ghPr.getPrComments(resolved.owner, resolved.name, prNum)
              val goal     = ghPr.buildReviewGoal(pr, diff, comments)

              println("▶ Knuckles — reviewing PR #" + prNum + ": " + pr["title"])
              println("")

              agent.run(goal, resolved.path, mode = :review)
            }
          }
        }
        _ => {
          println(fmt("unknown command: {}", command))
          println(result.text)
          sys.exit(1)
        }
      }
    }
  }
}
