/**
 * knuckles.core.format — tool result and prompt formatting
 *
 * Converts tool results and session state into the strings that
 * get added to the conversation history sent to the model.
 *
 * All functions here are pure string transformations — no I/O,
 * no LLM dependency, fully testable.
 *
 * ## Conversation structure
 *
 * Each agent turn produces two history entries:
 *
 * 1. **user turn** — the tool result, wrapped so the model can
 *    clearly see what the tool returned and whether it succeeded
 * 2. **assistant turn** — the model's raw response (stored as-is)
 *
 * The system prompt is built once at session start and is not
 * stored in history — it is prepended on every `buildPrompt` call.
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
  "knuckles.core.session",
)
val fs = import("slug.io.fs")
val path = import("slug.path")

// Strips ANSI escape codes from a string so control characters from
// coloured command output never enter session history.
val stripAnsi = fn(@str s) {
  val esc  = fromCodePoint(27)
  val step = fn(src, acc) {
    val i = src /> indexOf(esc)
    match i {
      -1 => acc + src
      _  => {
        val after = src[i + 1:]
        val end   = after /> indexOf("m")
        match end {
          -1 => acc + src[0:i]
          _  => recur(after[end + 1:], acc + src[0:i])
        }
      }
    }
  }
  step(s, "")
}

// --- tool result formatting ---

/**
 * formats a tool result into a user-turn message for the conversation.
 *
 * Success and failure are clearly distinguished so the model can
 * decide whether to retry, recover, or proceed.
 */
@export
@testWith(
  [{ ok: true,  tool: "read", output: "val x = 1" }],
    "<result tool=\"read\" status=\"ok\">\nval x = 1\n</result>",
  [{ ok: false, tool: "edit", output: "search string not found" }],
    "<result tool=\"edit\" status=\"error\">\nsearch string not found\n</result>",
)
val formatResult = fn(result) {
  val status = match result.ok { true => "ok" false => "error" }
  "<result tool=\"" + result.tool + "\" status=\"" + status + "\">\n" +
  stripAnsi(result.output) + "\n" +
  "</result>"
}

/**
 * formats the most recent tool result from the session as a user turn.
 *
 * Returns `nil` if there are no results yet.
 */
@export
val formatLastResult = fn(session) {
  match session.results {
    [] => nil
    rs => formatResult(rs[-1])
  }
}

// --- system prompt ---

val PROMPTS_DIR = path.localize(cfg("knuckles-prompts", "prompts"))

val loadPromptFile = fn(@str path) {
  match fs.exists(path) {
    true  => fs.readFile(path)
    false => ""
  }
}

val buildFactsBlock = fn(session) {
  match session.facts {
    [] => ""
    fs => "## Discovered facts\n\n" +
      (fs /> map(fn(f) { "- " + f }) /> join("\n")) + "\n"
  }
}

/**
 * builds the system prompt for the agent from markdown files.
 *
 * Loads `prompts/core.md` and `prompts/overlay/<mode>.md`, substitutes
 * dynamic values (goal, repoRoot, facts), then appends the Slug language
 * reference and module manifest.
 *
 * `mode` selects the task-specific overlay:
 * - `:local`  — pure local session, no git operations required
 * - `:issue`  — GitHub issue implementation, git workflow required
 * - `:review` — GitHub PR review, github_review tool
 * - `:report` — written report/document output
 *
 * The prompt files are reloaded on every call so edits take effect
 * without restarting the agent.
 */
@export
val buildSystemPrompt = fn(session, slugSpec, manifest, mode = :local) {
  val core    = loadPromptFile(PROMPTS_DIR + "/core.md")
  val overlay = loadPromptFile(PROMPTS_DIR + "/overlay/" + label(mode) + ".md")

  val factsBlock = buildFactsBlock(session)

  val filled = core
    /> replaceAll('{{goal}}',     session.goal)
    /> replaceAll('{{repoRoot}}', session.repoRoot)
    /> replaceAll('{{facts}}',    factsBlock)

  filled +
  match overlay /> trim {
    "" => ""
    _  => "\n\n" + overlay
  } +
  "\n\n## Slug language reference\n\n" + slugSpec +
  "\n\n## Module manifest\n\n" + manifest
}

// --- context window compression ---

val CONTEXT_THRESHOLD = cfg("knuckles-context-threshold", 30)
val CONTEXT_RECENT    = cfg("knuckles-context-recent",    10)

// Extracts the path or command argument from an assistant turn's XML tool call.
// Used to build the "files visited" list in the compressed summary.
val extractTurnPath = fn(@str content) {
  val path = content /> indexOf("<path>")
  val cmd  = content /> indexOf("<cmd>")
  match path {
    -1 => match cmd {
      -1 => nil
      _  => {
        val start = cmd + len("<cmd>")
        val end   = content /> indexOf("</cmd>", start)
        match end { -1 => nil _ => content[start:end] }
      }
    }
    _ => {
      val start = path + len("<path>")
      val end   = content /> indexOf("</path>", start)
      match end { -1 => nil _ => content[start:end] }
    }
  }
}

// Extracts the tool name from an assistant turn's XML tool call.
val extractTurnTool = fn(@str content) {
  val start = content /> indexOf("<tool>")
  match start {
    -1 => nil
    _  => {
      val cs  = start + len("<tool>")
      val end = content /> indexOf("</tool>", cs)
      match end { -1 => nil _ => content[cs:end] }
    }
  }
}

/**
 * builds a compact "what I've done so far" summary from old history turns
 * and structured session state.
 *
 * Covers:
 * - files and directories visited (read, list, grep, find)
 * - commands run and their outcome
 * - edits applied (from session.patches)
 * - errors encountered
 */
val buildContextSummary = fn(session, oldTurns) {
  // collect tool calls from old assistant turns
  val toolCalls = oldTurns
    /> filter(fn(t) { t.role == :assistant })
    /> map(fn(t) {{
      tool: extractTurnTool(t.content),
      path: extractTurnPath(t.content),
    }})
    /> filter(fn(tc) { tc.tool != nil })

  // files/dirs visited — read, list, grep, find
  val visited = toolCalls
    /> filter(fn(tc) {
      val t = tc.tool
      t == "read" || t == "list" || t == "grep" || t == "find"
    })
    /> map(fn(tc) { tc.path /> ifNil("?") })
    /> reduce([], fn(acc, p) {
      match acc /> find(fn(x) { x == p }) {
        nil => acc :+ p
        _   => acc
      }
    })

  // commands run — from run tool calls in old turns
  val ran = toolCalls
    /> filter(fn(tc) { tc.tool == "run" })
    /> map(fn(tc) { tc.path /> ifNil("?") })

  // errors from old results — tool calls that returned error status
  val errors = oldTurns
    /> filter(fn(t) {
      t.role == :user && t.content /> contains("status=\"error\"")
    })
    /> map(fn(t) {
      val start = t.content /> indexOf("tool=\"")
      match start {
        -1 => "unknown tool error"
        _  => {
          val ts  = start + len("tool=\"")
          val end = t.content /> indexOf("\"", ts)
          match end { -1 => "unknown tool error" _ => t.content[ts:end] + " error" }
        }
      }
    })

  // build the summary block
  val visitedBlock = match visited {
    [] => ""
    _  => "\n**Files/dirs visited:** " + join(visited, ", ")
  }

  val patchBlock = match session.patches {
    [] => ""
    ps => "\n**Edits applied:**\n" +
      (ps /> map(fn(p) { "  - " + p.path + " — " + p.desc }) /> join("\n"))
  }

  val ranBlock = match ran {
    [] => ""
    _  => "\n**Commands run:** " + join(ran, ", ")
  }

  val errorBlock = match errors {
    [] => ""
    _  => "\n**Errors encountered:** " + join(errors, ", ")
  }

  val factsBlock = match session.facts {
    [] => ""
    _  => "\n**Facts remembered:** " +
      (session.facts /> map(fn(f) { "\n  - " + f }) /> join(""))
  }

  "## What I've done so far (turns 1–" + toString(len(oldTurns)) + ")\n" +
  visitedBlock + patchBlock + ranBlock + errorBlock + factsBlock +
  "\n\n*Continuing from turn " + toString(session.turn - CONTEXT_RECENT) + "...*"
}

// --- conversation builder ---

/**
 * builds the messages list to send to the model.
 *
 * When history is short (<= `knuckles-context-threshold`, default 30 turns),
 * all turns are sent verbatim. When history grows long, turns older than
 * the most recent `knuckles-context-recent` (default 10) are compressed
 * into a compact summary block so the model retains awareness of what
 * has already been done without filling the context window with raw tool
 * output from early turns.
 *
 * The system prompt is always fresh — facts and goal state are current.
 * The compression is ephemeral — session history is never modified.
 */
@export
val buildMessages = fn(session, slugSpec, manifest, contextWindow = 20, mode = :local) {
  val system  = buildSystemPrompt(session, slugSpec, manifest, mode)
  val history = session.history
  val total   = len(history)

  val turns = match total > CONTEXT_THRESHOLD {
    false => {
      // short session — send all turns verbatim (up to contextWindow)
      val h = match total > contextWindow {
        true  => history[total - contextWindow:]
        false => history
      }
      h /> map(fn(t) {{ role: label(t.role), content: t.content }})
    }
    true => {
      // long session — compress old turns, keep recent verbatim
      val recentCount = CONTEXT_RECENT
      val splitAt     = total - recentCount
      val oldTurns    = history[0:splitAt]
      val recentTurns = history[splitAt:]
      val summary     = buildContextSummary(session, oldTurns)
      val summaryTurn = { role: "user", content: summary }
      val recent      = recentTurns /> map(fn(t) {{ role: label(t.role), content: t.content }})
      [summaryTurn] + recent
    }
  }

  [{ role: "user", content: system }] + turns
}

// --- done summary formatting ---

/**
 * formats the final session summary for display to the developer.
 */
@export
val formatSummary = fn(session) {
  val patchLines = match session.patches {
    [] => "  (no files modified)"
    ps => ps /> map(fn(p) { "  " + p.path + "\n    " + p.desc }) /> join("\n")
  }

  """
Knuckles — Task Complete
========================

Goal:  {{session.goal}}
Turns: {{session.turn}}

Changes:
{{patchLines}}

Summary:
{{session.summary}}
"""
}
