/**
 * knuckles.core.format — tool result and prompt formatting
 *
 * Converts tool results and session state into the strings that
 * get added to the conversation history sent to the model.
 *
 * All functions here are pure string transformations — no I/O,
 * no LLM dependency, fully testable.
 *
 * ## Conversation structure
 *
 * Each agent turn produces two history entries:
 *
 * 1. **user turn** — the tool result, wrapped so the model can
 *    clearly see what the tool returned and whether it succeeded
 * 2. **assistant turn** — the model's raw response (stored as-is)
 *
 * The system prompt is built once at session start and is not
 * stored in history — it is prepended on every `buildPrompt` call.
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
  "knuckles.core.session",
)

// Strips ANSI escape codes from a string so control characters from
// coloured command output never enter session history.
val stripAnsi = fn(@str s) {
  val esc  = fromCodePoint(27)
  val step = fn(src, acc) {
    val i = src /> indexOf(esc)
    match i {
      -1 => acc + src
      _  => {
        val after = src[i + 1:]
        val end   = after /> indexOf("m")
        match end {
          -1 => acc + src[0:i]
          _  => recur(after[end + 1:], acc + src[0:i])
        }
      }
    }
  }
  step(s, "")
}

// --- tool result formatting ---

/**
 * formats a tool result into a user-turn message for the conversation.
 *
 * Success and failure are clearly distinguished so the model can
 * decide whether to retry, recover, or proceed.
 */
@export
@testWith(
  [{ ok: true,  tool: "read", output: "val x = 1" }],
    "<result tool=\"read\" status=\"ok\">\nval x = 1\n</result>",
  [{ ok: false, tool: "edit", output: "search string not found" }],
    "<result tool=\"edit\" status=\"error\">\nsearch string not found\n</result>",
)
val formatResult = fn(result) {
  val status = match result.ok { true => "ok" false => "error" }
  "<result tool=\"" + result.tool + "\" status=\"" + status + "\">\n" +
  stripAnsi(result.output) + "\n" +
  "</result>"
}

/**
 * formats the most recent tool result from the session as a user turn.
 *
 * Returns `nil` if there are no results yet.
 */
@export
val formatLastResult = fn(session) {
  match session.results {
    [] => nil
    rs => formatResult(rs[-1])
  }
}

// --- system prompt ---

/**
 * builds the system prompt for the agent.
 *
 * The system prompt is assembled from:
 * - the agent's role and capabilities
 * - the tool call XML format with examples
 * - the current goal
 * - the repo root path
 * - any facts accumulated so far
 *
 * It is prepended to every `buildMessages` call and is not stored
 * in the session history.
 */
@export
val buildSystemPrompt = fn(session, slugSpec, manifest) {
  val factsBlock = match session.facts {
    [] => ""
    fs => "\n## Discovered facts\n\n" + fs /> map(fn(f) { "- " + f }) /> join("\n") + "\n"
  }

  '''
You are Knuckles, a Slug coding agent. You help developers inspect, understand,
and modify Slug codebases through a small set of explicit tools.

## Your task

Goal: ''' + session.goal + '''
Repo: ''' + session.repoRoot + '''

## Rules

- Think step by step before calling a tool.
- Call exactly one tool per response.
- Always read a file before editing it.
- For edits, make the search string unique enough to match exactly once.
- When the task is complete call the done tool with a clear summary.
- Do not guess at file contents — read first.
- Do not modify files outside the repo root.
- Always use relative paths in run commands — the working directory is always
  the repo root. Never pass absolute paths to slug test or other tools.
- If `slug test --dir .` produces a `searchModuleTags` error mentioning a module
  that imports other local modules (e.g. a main app file), that is a test runner
  path issue — the module's imports cannot resolve from the repo root. Do NOT try
  to fix the imports. Instead: remember the issue, then test individual library
  files directly (e.g. `slug test --dir crochet-app`) or test files one at a time.
- If `Error: not a function: LIST` appears in test output, it means a function
  is being called with wrong argument types at module load time. Check whether
  a `...fns` variadic function is receiving a list where it expects spread args.
- Use remember when you discover something stable and worth keeping across turns
  (e.g. what a module does, where a key function lives, a constraint you must respect).
  Facts appear in every future prompt — keep them short, one sentence each.
- After a successful edit the test suite may run automatically — check the result
  before proceeding. If tests fail, fix the issue before calling done.
- If requirements are ambiguous or a decision requires human judgement, use the
  prompt tool to ask before proceeding. One focused question per prompt call.

## Tool call format

Emit exactly one tool call per response using XML tags:

<tool>read</tool><path>src/eval.slug</path>

<tool>edit</tool><path>src/eval.slug</path>
<search>val cache = nil</search>
<replace>val cache = {}</replace>
<desc>initialise cache as empty map</desc>

<tool>list</tool><path>src</path>

<tool>find</tool><pattern>import</pattern><path>src</path>

<tool>write</tool><path>src/new.slug</path>
<content>val x = 1</content>

<tool>run</tool><cmd>slug test src/eval.slug</cmd>

<tool>remember</tool><fact>knuckles.core.session owns all immutable state transforms</fact>

<tool>prompt</tool><question>Should the timeout be configurable or always 30 seconds?</question>

<tool>grep</tool><pattern>addHistory</pattern>

<tool>grep</tool><pattern>fn\(.*session</pattern><path>knuckles</path>

<tool>grep</tool><pattern>import</pattern><flags>-l</flags>

<tool>diff</tool>

<tool>done</tool>
<summary>Added caching to the evaluator. Modified src/eval.slug and updated tests.</summary>

## Available tools

| Tool     | Args                                      | Purpose                              |
|----------|-------------------------------------------|--------------------------------------|
| read     | path                                      | read a file                          |
| list     | path                                      | list directory contents              |
| find     | pattern, path (optional)                  | plain string search in .slug files   |
| grep     | pattern, path (optional), flags (optional)| regex search across all file types   |
| write    | path, content                             | create or overwrite a file           |
| edit     | path, search, replace, desc               | surgical single-occurrence edit      |
| revert   | path                                      | undo the last edit to a file         |
| run      | cmd                                       | run a shell command                  |
| git_status   | (none)                                | show working tree status             |
| git_diff     | (none)                                | show unstaged and staged changes     |
| git_log      | n (optional)                          | show last N commits                  |
| git_commit   | message                               | stage all changes and commit         |
| git_push     | branch                                | push branch to origin                |
| github_review | owner, repo, number, body, event     | post a PR review                     |
| prompt   | question                                  | ask the developer a question         |
| remember | fact                                      | store a fact that persists in prompt |
| diff     | (none)                                    | show all knuckles patches so far     |
| done     | summary                                   | finish and summarise the task        |

- For issue implementation tasks: read and edit files, then git_status → git_commit → git_push → done.
  You MUST call git_commit before done if any files were modified. If you skip git_commit,
  the system will auto-commit your changes but you will not control the commit message.
Only call git_push when edits are complete and tests pass. Never force-push.

Prefer `grep` over `find` when you need regex, want to search non-.slug files, or need
to find all callers/imports of a symbol across the whole codebase. Use `grep -l` to get
filenames only, `-i` for case-insensitive, `-w` for whole-word matching.
''' + factsBlock + "\n## Slug language reference\n\n" + slugSpec +
  "\n## Module manifest\n\n" + manifest
}

// --- context window compression ---

val CONTEXT_THRESHOLD = cfg("knuckles_context_threshold", 30)
val CONTEXT_RECENT    = cfg("knuckles_context_recent",    10)

// Extracts the path or command argument from an assistant turn's XML tool call.
// Used to build the "files visited" list in the compressed summary.
val extractTurnPath = fn(@str content) {
  val path = content /> indexOf("<path>")
  val cmd  = content /> indexOf("<cmd>")
  match path {
    -1 => match cmd {
      -1 => nil
      _  => {
        val start = cmd + len("<cmd>")
        val end   = content /> indexOf("</cmd>", start)
        match end { -1 => nil _ => content[start:end] }
      }
    }
    _ => {
      val start = path + len("<path>")
      val end   = content /> indexOf("</path>", start)
      match end { -1 => nil _ => content[start:end] }
    }
  }
}

// Extracts the tool name from an assistant turn's XML tool call.
val extractTurnTool = fn(@str content) {
  val start = content /> indexOf("<tool>")
  match start {
    -1 => nil
    _  => {
      val cs  = start + len("<tool>")
      val end = content /> indexOf("</tool>", cs)
      match end { -1 => nil _ => content[cs:end] }
    }
  }
}

/**
 * builds a compact "what I've done so far" summary from old history turns
 * and structured session state.
 *
 * Covers:
 * - files and directories visited (read, list, grep, find)
 * - commands run and their outcome
 * - edits applied (from session.patches)
 * - errors encountered
 */
val buildContextSummary = fn(session, oldTurns) {
  // collect tool calls from old assistant turns
  val toolCalls = oldTurns
    /> filter(fn(t) { t.role == :assistant })
    /> map(fn(t) {{
      tool: extractTurnTool(t.content),
      path: extractTurnPath(t.content),
    }})
    /> filter(fn(tc) { tc.tool != nil })

  // files/dirs visited — read, list, grep, find
  val visited = toolCalls
    /> filter(fn(tc) {
      val t = tc.tool
      t == "read" || t == "list" || t == "grep" || t == "find"
    })
    /> map(fn(tc) { tc.path /> ifNil("?") })
    /> reduce([], fn(acc, p) {
      match acc /> find(fn(x) { x == p }) {
        nil => acc :+ p
        _   => acc
      }
    })

  // commands run — from run tool calls in old turns
  val ran = toolCalls
    /> filter(fn(tc) { tc.tool == "run" })
    /> map(fn(tc) { tc.path /> ifNil("?") })

  // errors from old results — tool calls that returned error status
  val errors = oldTurns
    /> filter(fn(t) {
      t.role == :user && t.content /> contains("status=\"error\"")
    })
    /> map(fn(t) {
      val start = t.content /> indexOf("tool=\"")
      match start {
        -1 => "unknown tool error"
        _  => {
          val ts  = start + len("tool=\"")
          val end = t.content /> indexOf("\"", ts)
          match end { -1 => "unknown tool error" _ => t.content[ts:end] + " error" }
        }
      }
    })

  // build the summary block
  val visitedBlock = match visited {
    [] => ""
    _  => "\n**Files/dirs visited:** " + join(visited, ", ")
  }

  val patchBlock = match session.patches {
    [] => ""
    ps => "\n**Edits applied:**\n" +
      (ps /> map(fn(p) { "  - " + p.path + " — " + p.desc }) /> join("\n"))
  }

  val ranBlock = match ran {
    [] => ""
    _  => "\n**Commands run:** " + join(ran, ", ")
  }

  val errorBlock = match errors {
    [] => ""
    _  => "\n**Errors encountered:** " + join(errors, ", ")
  }

  val factsBlock = match session.facts {
    [] => ""
    _  => "\n**Facts remembered:** " +
      (session.facts /> map(fn(f) { "\n  - " + f }) /> join(""))
  }

  "## What I've done so far (turns 1–" + toString(len(oldTurns)) + ")\n" +
  visitedBlock + patchBlock + ranBlock + errorBlock + factsBlock +
  "\n\n*Continuing from turn " + toString(session.turn - CONTEXT_RECENT) + "...*"
}

// --- conversation builder ---

/**
 * builds the messages list to send to the model.
 *
 * When history is short (<= `knuckles_context_threshold`, default 30 turns),
 * all turns are sent verbatim. When history grows long, turns older than
 * the most recent `knuckles_context_recent` (default 10) are compressed
 * into a compact summary block so the model retains awareness of what
 * has already been done without filling the context window with raw tool
 * output from early turns.
 *
 * The system prompt is always fresh — facts and goal state are current.
 * The compression is ephemeral — session history is never modified.
 */
@export
val buildMessages = fn(session, slugSpec, manifest, contextWindow = 20) {
  val system  = buildSystemPrompt(session, slugSpec, manifest)
  val history = session.history
  val total   = len(history)

  val turns = match total > CONTEXT_THRESHOLD {
    false => {
      // short session — send all turns verbatim (up to contextWindow)
      val h = match total > contextWindow {
        true  => history[total - contextWindow:]
        false => history
      }
      h /> map(fn(t) {{ role: label(t.role), content: t.content }})
    }
    true => {
      // long session — compress old turns, keep recent verbatim
      val recentCount = CONTEXT_RECENT
      val splitAt     = total - recentCount
      val oldTurns    = history[0:splitAt]
      val recentTurns = history[splitAt:]
      val summary     = buildContextSummary(session, oldTurns)
      val summaryTurn = { role: "user", content: summary }
      val recent      = recentTurns /> map(fn(t) {{ role: label(t.role), content: t.content }})
      [summaryTurn] + recent
    }
  }

  [{ role: "user", content: system }] + turns
}

// --- done summary formatting ---

/**
 * formats the final session summary for display to the developer.
 */
@export
val formatSummary = fn(session) {
  val patchLines = match session.patches {
    [] => "  (no files modified)"
    ps => ps /> map(fn(p) { "  " + p.path + "\n    " + p.desc }) /> join("\n")
  }

  """
Knuckles — Task Complete
========================

Goal:  {{session.goal}}
Turns: {{session.turn}}

Changes:
{{patchLines}}

Summary:
{{session.summary}}
"""
}
