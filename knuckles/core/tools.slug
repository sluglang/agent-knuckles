/**
 * knuckles.core.tools — agent tool implementations
 *
 * Each tool takes the current session and a string-keyed args map,
 * executes its operation, and returns `{ ok, output, session }`.
 *
 * The session is returned so tools can record their result via
 * `addResult` and callers always get back the updated state.
 *
 * ## Path safety
 *
 * All tools that accept a `path` argument resolve it through
 * `session.absPath` and validate it with `session.isSafePath`.
 * Paths outside `repoRoot` or containing `..` are rejected.
 *
 * ## Tool contracts
 *
 * | Tool    | Args                          | Returns                         |
 * |---------|-------------------------------|---------------------------------|
 * | `read`  | `path`                        | file contents as string         |
 * | `list`  | `path`                        | newline-separated file listing  |
 * | `find`  | `pattern`, `path?`            | matching lines with file:line   |
 * | `write` | `path`, `content`             | confirmation string             |
 * | `edit`  | `path`, `search`, `replace`, `desc` | confirmation + line count |
 * | `run`   | `cmd`                         | stdout + stderr                 |
 * | `diff`  | (none)                        | summary of all patches so far   |
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
)
val fs      = import("slug.io.fs")
val sys     = import("slug.sys")
val stdin   = import("slug.io.stdin")
val session = import("knuckles.core.session")

// --- result helpers ---

val toolOk  = fn(s, tool, output) {{ ok: true,  output: output, session: session.addResult(s, tool, true,  output) }}
val toolErr = fn(s, tool, msg)    {{ ok: false, output: msg,    session: session.addResult(s, tool, false, msg)    }}

// --- path guard ---
// Resolves and validates a path. Returns { ok, path, session } or an error result.

val resolvePath = fn(s, tool, rawPath) {
  match session.isSafePath(s, rawPath) {
    false => {{ ok: false, path: nil, err: "unsafe path: " + rawPath }}
    true  => {{ ok: true,  path: session.absPath(s, rawPath), err: nil }}
  }
}

// ============================================================
// read — read entire file contents
// ============================================================

/**
 * reads the entire contents of a file and returns it as a string.
 *
 * Fails if the path is outside `repoRoot` or the file does not exist.
 */
@export
val read = fn(s, args) {
  val rawPath = args["path"]
  val r       = resolvePath(s, "read", rawPath)
  match r.ok {
    false => toolErr(s, "read", r.err)
    true  => match fs.exists(r.path) {
      false => toolErr(s, "read", "file not found: " + rawPath)
      true  => toolOk(s, "read", fs.readFile(r.path))
    }
  }
}

// ============================================================
// list — list directory contents recursively
// ============================================================

// Directories and filename patterns that are never useful to the agent.
val IGNORE_DIRS = [".git", ".idea", ".vscode", "node_modules", "__pycache__"]
val IGNORE_EXTS = [".DS_Store", ".db", ".sqlite", ".zip", ".tar", ".gz", ".png", ".jpg", ".jpeg", ".gif", ".ico", ".woff", ".ttf"]

val isIgnored = fn(path) {
  val ignored = IGNORE_DIRS /> find(fn(d) { path /> contains("/" + d + "/") || path /> startsWith(d + "/") })
  val ext     = IGNORE_EXTS /> find(fn(e) { path /> endsWith(e) })
  ignored != nil || ext != nil
}

/**
 * lists all files under `path` recursively, excluding noise directories
 * and binary/generated files.
 *
 * Filters out: `.git`, `.idea`, `.vscode`, `node_modules`, `__pycache__`,
 * database files, archives, images, and font files.
 *
 * Returns a newline-separated list of paths relative to `repoRoot`.
 * Fails if path is not a directory.
 */
@export
val list = fn(s, args) {
  val rawPath = args["path"] /> ifNil(".")
  val r       = resolvePath(s, "list", rawPath)
  match r.ok {
    false => toolErr(s, "list", r.err)
    true  => match fs.isDir(r.path) {
      false => toolErr(s, "list", "not a directory: " + rawPath)
      true  => {
        val rootLen  = len(s.repoRoot + "/")
        val files    = fs.listFilesRecursive([r.path])
        val relative = files
          /> map(fn(f) { f[rootLen:] })
          /> filter(fn(f) { !isIgnored(f) })
        toolOk(s, "list", relative /> join("\n"))
      }
    }
  }
}

// ============================================================
// find — search for a pattern across source files
// ============================================================

/**
 * searches for lines matching `pattern` (plain string) in files under `path`.
 *
 * Returns matching lines in `file:linenum: content` format.
 * `path` defaults to the repo root. Only searches `.slug` files by default.
 */
@export
val find = fn(s, args) {
  val pattern = args["pattern"]
  val rawPath = args["path"] /> ifNil(".")
  val r       = resolvePath(s, "find", rawPath)
  match r.ok {
    false => toolErr(s, "find", r.err)
    true  => {
      val files   = fs.listFilesRecursive([r.path], fn(f) { f /> endsWith(".slug") })
      val rootLen = len(s.repoRoot + "/")
      val matches = files /> flatMap(fn(file) {
        val content = fs.readFile(file)
        val relPath = file[rootLen:]
        content /> split("\n") /> zipWithIndex /> flatMap(fn(pair) {
          val line    = pair[0]
          val lineNum = pair[1] + 1
          match line /> contains(pattern) {
            true  => [relPath + ":" + lineNum + ": " + line]
            false => []
          }
        })
      })
      match matches {
        [] => toolOk(s, "find", "no matches for: " + pattern)
        _  => toolOk(s, "find", matches /> join("\n"))
      }
    }
  }
}

// ============================================================
// write — write or overwrite a file
// ============================================================

/**
 * writes `content` to `path`, creating the file if it does not exist.
 *
 * The parent directory must already exist. Use with care — this
 * overwrites without confirmation. For modifications to existing files,
 * prefer `edit`.
 */
@export
val write = fn(s, args) {
  val rawPath = args["path"]
  val content = args["content"]
  val r       = resolvePath(s, "write", rawPath)
  match r.ok {
    false => toolErr(s, "write", r.err)
    true  => {
      fs.writeFile(content, r.path)
      toolOk(s, "write", "written: " + rawPath + " (" + len(content) + " chars)")
    }
  }
}

// ============================================================
// edit — surgical single-occurrence string replacement
// ============================================================

// Shared command execution helper used by both `run` and `edit`.
// Runs cmd in repoRoot, returns combined stdout+stderr string.
val execCommand = fn(s, cmd) {
  val timeoutMs  = cfg("run_timeout_ms", 30000)
  val cdCmd      = "cd " + s.repoRoot + " && " + cmd
  val [out, err] = sys.exec(cdCmd, timeoutMs)
  match err /> trim {
    "" => out
    _  => out + "\n[stderr]\n" + err
  }
}

/**
 * replaces exactly one occurrence of `search` with `replace` in `path`.
 *
 * Fails explicitly if:
 * - `search` and `replace` are identical (no-op edit)
 * - the file does not exist
 * - `search` is not found in the file
 * - `search` matches more than one location
 *
 * The strictness is intentional — the model must construct a `search`
 * string unique enough to identify exactly the right location. This
 * prevents accidental multi-site edits and forces precise context.
 *
 * On success, records the patch in the session. If `cfg("run_after_edit")`
 * is set, that command is run automatically and its output is appended
 * to the result so the model can see whether the edit broke anything.
 */
@export
val edit = fn(s, args) {
  val rawPath = args["path"]
  val search  = args["search"]
  val replace = args["replace"]
  val desc    = args["desc"] /> ifNil("edit " + rawPath)

  // reject no-op edits — search and replace are identical, nothing would change
  match search == replace {
    true => toolErr(s, "edit",
      "search and replace are identical — no change would be made. " +
      "Use a more specific search string that targets exactly the line(s) you want to change."
    )
    false => {
      val r = resolvePath(s, "edit", rawPath)
      match r.ok {
        false => toolErr(s, "edit", r.err)
        true  => match fs.exists(r.path) {
          false => toolErr(s, "edit", "file not found: " + rawPath)
          true  => {
            val content    = fs.readFile(r.path)
            val firstMatch = content /> indexOf(search)
            match firstMatch {
              -1 => toolErr(s, "edit", "search string not found in: " + rawPath)
              _  => {
                val secondMatch = content /> indexOf(search, firstMatch + len(search))
                match secondMatch {
                  n if n >= 0 => toolErr(s, "edit",
                    "search string matches multiple locations in: " + rawPath +
                    " — make it more specific"
                  )
                  _ => {
                    val updated = content[0:firstMatch] + replace + content[firstMatch + len(search):]
                    fs.writeFile(updated, r.path)
                    val s2 = session.addPatch(s, rawPath, search, replace, desc)

                    // auto-run test command if configured
                    val testCmd    = cfg("run_after_edit", nil)
                    val testOutput = match testCmd {
                      nil => ""
                      cmd => "\n\n[auto-run: " + cmd + "]\n" + execCommand(s2, cmd)
                    }

                    toolOk(s2, "edit", "edited: " + rawPath + " — " + desc + testOutput)
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

// ============================================================
// run — execute a shell command
// ============================================================

/**
 * runs a shell command synchronously and returns stdout + stderr.
 *
 * The command is executed with the repo root as working directory.
 * Timeout is controlled by `cfg("run_timeout_ms", 30000)`.
 * Both stdout and stderr are returned regardless of exit code.
 */
@export
val run = fn(s, args) {
  toolOk(s, "run", execCommand(s, args["cmd"]))
}

// ============================================================
// diff — summarise all patches applied so far
// ============================================================

/**
 * returns a summary of all patches applied in this session.
 *
 * Shows each file edited and its description. Useful for the model
 * to review what has been changed before calling `done`.
 */
@export
val diff = fn(s, args) {
  toolOk(s, "diff", session.patchSummary(s))
}

// ============================================================
// remember — store a durable fact in session state
// ============================================================

/**
 * stores a fact in the session's `facts` list.
 *
 * Facts are injected into the system prompt on every turn so they
 * persist across the context window. Use this to record stable
 * discoveries that are worth remembering regardless of how long
 * the session runs — module purposes, key function names, design
 * decisions, constraints.
 *
 * Facts should be concise — one sentence each.
 */
@export
val remember = fn(s, args) {
  val fact = args["fact"]
  val s2   = session.addFact(s, fact)
  toolOk(s2, "remember", "remembered: " + fact)
}

// ============================================================
// grep — regex search across all files using system grep
// ============================================================

/**
 * runs `grep -rn` in the repo root and returns matching lines.
 *
 * Unlike `find`, which does plain string matching on `.slug` files only,
 * `grep` uses full regex, searches all file types, and is significantly
 * faster on large repos. Use it when you need:
 * - regex patterns (e.g. `fn\(.*session`)
 * - cross-file symbol search (all callers, all imports)
 * - searching non-.slug files (config, SQL, markdown)
 *
 * Args:
 * - `pattern` (required) — regex pattern passed directly to grep
 * - `path`    (optional) — directory or file to search; defaults to repo root
 * - `flags`   (optional) — extra grep flags e.g. `-i` (case-insensitive),
 *                          `-l` (filenames only), `-w` (whole word)
 */
@export
val grep = fn(s, args) {
  val pattern = args["pattern"]
  val rawPath = args["path"] /> ifNil(".")
  val flags   = args["flags"] /> ifNil("")
  val r       = resolvePath(s, "grep", rawPath)
  match r.ok {
    false => toolErr(s, "grep", r.err)
    true  => {
      val excludes = "--exclude-dir=.git --exclude-dir=.idea --exclude-dir=.vscode --exclude-dir=node_modules"
      val flagStr  = match flags /> trim {
        "" => ""
        f  => " " + f
      }
      val cmd    = "grep -rn" + flagStr + " " + excludes + " -- '" + pattern + "' " + r.path
      val output = execCommand(s, cmd)
      match output /> trim {
        "" => toolOk(s, "grep", "no matches for: " + pattern)
        _  => {
          val rootLen  = len(s.repoRoot + "/")
          val lines    = output /> split("\n") /> filter(fn(l) { len(l /> trim) > 0 })
          val relative = lines /> map(fn(l) {
            match l /> startsWith(s.repoRoot + "/") {
              true  => l[rootLen:]
              false => l
            }
          })
          toolOk(s, "grep", relative /> join("\n"))
        }
      }
    }
  }
}

// ============================================================
// prompt — ask the developer a question and wait for their answer
// ============================================================

/**
 * pauses execution, prints `question` to the terminal, and waits for
 * the developer to type a response.
 *
 * The answer is returned as the tool result and is also automatically
 * stored as a session fact so it persists across context window
 * compression — answers to requirement questions are exactly the kind
 * of stable knowledge that should survive long sessions.
 *
 * Use this when:
 * - requirements are ambiguous or missing
 * - a design decision requires human judgement
 * - you need confirmation before a destructive or irreversible action
 *
 * The question should be specific and answerable — not "what should I do?"
 * but "should the timeout default to 30s or be required?" or
 * "should I overwrite the existing file or create a new one?"
 */
@export
val prompt = fn(s, args) {
  val question = args["question"]
  println("")
  println("┌─ Knuckles needs input " + padRight("", "─", 54) + "┐")
  println("│ " + question)
  println("└" + padRight("", "─", 77) + "┘")
  val answer = stdin.prompt("▶ ")
  match answer {
    nil => toolErr(s, "prompt",
      "no input received — session may be running non-interactively"
    )
    _ => {
      val fact = "Developer answered \"" + question + "\": " + answer
      val s2   = session.addFact(s, fact)
      toolOk(s2, "prompt", "Developer says: " + answer)
    }
  }
}

// ============================================================
// git tools — status, diff, log, commit, push
// ============================================================
// These tools give the agent visibility into and control over
// the git working tree. Clone and branch creation happen at
// session setup time and are not available as agent tools.

val gitRepo = import("knuckles.github.repo")

/**
 * shows the working tree status (modified, staged, untracked files).
 */
@export
val git_status = fn(s, args) {
  toolOk(s, "git_status", gitRepo.status(s.repoRoot))
}

/**
 * shows the current diff (unstaged and staged changes).
 */
@export
val git_diff = fn(s, args) {
  toolOk(s, "git_diff", gitRepo.diff(s.repoRoot))
}

/**
 * shows the last N commits on the current branch (default: 10).
 */
@export
val git_log = fn(s, args) {
  val n = args["n"] /> ifNil("10") /> toNumber /> ifNil(10)
  toolOk(s, "git_log", gitRepo.log(s.repoRoot, n))
}

/**
 * stages all changes and commits with the given message.
 *
 * Records the commit as a patch in the session for traceability.
 */
@export
val git_commit = fn(s, args) {
  val message = args["message"]
  val result  = gitRepo.commit(s.repoRoot, message)
  val s2      = session.addPatch(s, "[commit]", "", result.sha, message)
  toolOk(s2, "git_commit", "committed: " + result.sha + " — " + message)
}

/**
 * pushes the current branch to origin.
 *
 * Only call this when all edits are complete and tests pass.
 */
@export
val git_push = fn(s, args) {
  val branch = args["branch"]
  val output = gitRepo.push(s.repoRoot, branch)
  toolOk(s, "git_push", output)
}

// ============================================================
// github_review — post a structured PR review
// ============================================================

/**
 * posts a review on a GitHub PR.
 *
 * Args:
 * - `owner`   — repo owner
 * - `repo`    — repo name
 * - `number`  — PR number
 * - `body`    — overall review summary
 * - `event`   — COMMENT | APPROVE | REQUEST_CHANGES
 */
@export
val github_review = fn(s, args) {
  val pr     = import("knuckles.github.pr")
  val owner  = args["owner"]
  val repo   = args["repo"]
  val number = args["number"] /> toNumber
  val body   = args["body"]
  val event  = args["event"] /> ifNil("COMMENT")
  pr.postReview(owner, repo, number, body, event, [])
  toolOk(s, "github_review", "posted " + event + " review on PR #" + number)
}

// ============================================================
// dispatch — route an action to the correct tool
// ============================================================

/**
 * dispatches a parsed `Action` to the appropriate tool function.
 *
 * Returns `{ ok, output, session }`. If the action type is unknown
 * or is `:error`, returns an error result without touching the session.
 */
@export
val dispatch = fn(s, action) {
  match action.type {
    :read          => read(s,          action.args)
    :list          => list(s,          action.args)
    :find          => find(s,          action.args)
    :grep          => grep(s,          action.args)
    :write         => write(s,         action.args)
    :edit          => edit(s,          action.args)
    :revert        => revert(s,        action.args)
    :run           => run(s,           action.args)
    :diff          => diff(s,          action.args)
    :prompt        => prompt(s,        action.args)
    :remember      => remember(s,      action.args)
    :git_status    => git_status(s,    action.args)
    :git_diff      => git_diff(s,      action.args)
    :git_log       => git_log(s,       action.args)
    :git_commit    => git_commit(s,    action.args)
    :git_push      => git_push(s,      action.args)
    :github_review => github_review(s, action.args)
    :error         => toolErr(s, "dispatch", action.args["msg"] /> ifNil("unknown error"))
    t              => toolErr(s, "dispatch", "no tool for action type: " + label(t))
  }
}
