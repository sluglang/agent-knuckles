/**
 * knuckles.agent — agent execution loop
 *
 * Wires together `knuckles.core` and `knuckles.store` into the
 * full agent loop. Calls Ollama, parses the response, dispatches
 * the tool, persists state, and repeats until done or the turn
 * limit is reached.
 *
 * ## Execution model
 *
 * ```
 * session
 *   /> nextTurn
 *   /> buildMessages
 *   /> ollamaChat
 *   /> parseAction
 *   /> validateAction
 *   /> dispatch
 *   /> addHistory (tool result as user turn)
 *   /> saveSession
 *   /> runLoop   (recur, or finish)
 * ```
 *
 * Each iteration is a pure transformation on the session value.
 * The session is persisted to SQLite after every tool call so
 * that a crash at any point leaves a recoverable state.
 *
 * ## Configuration
 *
 * | Key                  | Default        | Description                         |
 * |----------------------|----------------|-------------------------------------|
 * | `knuckles-db`        | `knuckles.db`  | SQLite database path                |
 * | `knuckles-model`     | `llama3`       | Ollama model name                   |
 * | `ollama_url`         | `http://localhost:11434` | Ollama base URL           |
 * | `knuckles-max-turns` | `50`           | Maximum turns before giving up      |
 * | `knuckles-context`   | `20`           | History turns sent to model         |
 * | `run-timeout-ms`     | `30000`        | Shell command timeout in ms         |
 * | `knuckles-slug-spec` | `SLUG.ai`      | Path to SLUG.ai for system prompt   |
 * | `knuckles-manifest`  | `MANIFEST.ai`  | Path to MANIFEST.ai for system prompt |
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
)
val db      = import("slug.io.db")
val fs      = import("slug.io.fs")
val ollama  = import("slug.thirdparty.ollama")
val session = import("knuckles.core.session")
val parse   = import("knuckles.core.parse")
val tools   = import("knuckles.core.tools")
val format  = import("knuckles.core.format")
val store   = import("knuckles.store")
val path    = import("slug.path")

val MAX_TURNS   = cfg("knuckles-max-turns", 50)
val CONTEXT     = cfg("knuckles-context",   20)
val MODEL       = cfg("knuckles-model",     "llama3")
val SLUG_SPEC   = path.localize(cfg("knuckles-slug-spec", "SLUG.ai"))
val MANIFEST    = path.localize(cfg("knuckles-manifest",  "MANIFEST.ai"))

// --- spec loading ---
// Loaded once at startup; missing files degrade gracefully.

val loadSpec = fn(@str path) {
  match fs.exists(path) {
    true  => fs.readFile(path)
    false => "// " + path + " not found"
  }
}

// --- turn logging ---

val logTurn = fn(s, action) {
  val thought = match action.thought /> trim {
    "" => ""
    t  => "\n  " + t
  }
  println(fmt(
    "[turn {:d}] {} {}{}",
    s.turn,
    label(action.type),
    action.args["path"] /> ifNil(action.args["cmd"] /> ifNil("")),
    thought,
  ))
}

val gitRepo = import("knuckles.github.repo")

// Returns true if there are file patches that have not yet been committed.
// Commit patches are recorded with path "[commit]" by the git_commit tool.
val hasUncommittedChanges = fn(s) {
  val filePatches   = s.patches /> filter(fn(p) { p.path != "[commit]" })
  val commitPatches = s.patches /> filter(fn(p) { p.path == "[commit]" })
  len(filePatches) > 0 && len(commitPatches) == 0
}

// Builds a concise commit message from the session summary and patches.
val buildCommitMessage = fn(s) {
  val patchList = s.patches
    /> filter(fn(p) { p.path != "[commit]" })
    /> map(fn(p) { p.path })
    /> reduce([], fn(acc, p) {
      match acc /> find(fn(x) { x == p }) { nil => acc :+ p _ => acc }
    })
    /> join(", ")
  match s.summary /> trim {
    "" => "knuckles: update " + patchList
    sm => "knuckles: " + sm[0:72]
  }
}

val promptWithHook = fn(s, action, ask) {
  val question = action.args["question"] /> ifNil("")
  val answer = ask(question, s, action)
  match answer {
    nil => {
      val msg = "no input received — session is running non-interactively"
      val s2  = session.addResult(s, "prompt", false, msg)
      { ok: false, output: msg, session: s2 }
    }
    _ => {
      val fact = "Developer answered \"" + question + "\": " + answer
      val out  = "Developer says: " + answer
      val s2 = s
        /> session.addFact(fact)
        /> session.addResult("prompt", true, out)
      { ok: true, output: out, session: s2 }
    }
  }
}

val dispatchTool = fn(s, action, valErr, ask) {
  match valErr {
    nil => match action.type == :prompt && ask != nil {
      true => promptWithHook(s, action, ask)
      false => tools.dispatch(s, action)
    }
    msg => {{ ok: false, output: msg, session: s }}
  }
}

val runLoop = fn(conn, id, s, slugSpec, manifest, mode = :local, hooks = {}) {
  val onTurn = hooks["onTurn"] /> ifNil(fn() {fn(s, action) { logTurn(s, action) }})
  val onThought = hooks["onThought"] /> ifNil(fn() {fn(s, thought, action) { nil }})
  val onToolStart = hooks["onToolStart"] /> ifNil(fn() {fn(s, action) { nil }})
  val onToolResult = hooks["onToolResult"] /> ifNil(fn() {fn(s, action, toolResult, patch) { nil }})
  val onDone = hooks["onDone"] /> ifNil(fn() {fn(s) {
    println("")
    println(format.formatSummary(s))
  }})
  val onLimit = hooks["onLimit"] /> ifNil(fn() {fn(s, message) {
    println("⚠ " + message)
  }})
  val onModelNil = hooks["onModelNil"] /> ifNil(fn() {fn(s) {
    println("✗ Model returned nil — retrying next turn")
  }})
  val ask = hooks["ask"]

  // turn limit guard
  match s.turn >= MAX_TURNS {
    true => {
      val limitMsg = "Turn limit reached (" + MAX_TURNS + "). Task incomplete."
      val s2 = session.finish(s, limitMsg)
      store.saveSession(conn, id, s2)
      onLimit(s2, limitMsg)
      s2
    }
    false => {
      val s1 = session.nextTurn(s)

      // build messages and call the model
      val messages  = format.buildMessages(s1, slugSpec, manifest, CONTEXT, mode)
      val response  = ollama.ollamaChat(messages, model = MODEL)

      // handle model failure
      match response {
        nil => {
          onModelNil(s1)
          val nilMsg = "<result tool=\"error\" status=\"error\">\nModel returned no response. Please try again.\n</r>"
          val s2 = s1 /> session.addHistory(:assistant, "[no response]")
          store.appendTurn(conn, id, s2.turn, :assistant, "[no response]")
          val s3 = s2 /> session.addHistory(:user, nilMsg)
          store.appendTurn(conn, id, s3.turn, :user, nilMsg)
          store.saveSession(conn, id, s3)
          recur(conn, id, s3, slugSpec, manifest, mode, hooks)
        }
        _ => {
          // parse and validate the action
          val action = parse.parseAction(response)
          val valErr = parse.validateAction(action)

          onThought(s1, action.thought, action)
          onTurn(s1, action)

          // record the assistant turn — persist immediately
          val s2 = s1 /> session.addHistory(:assistant, response)
          store.appendTurn(conn, id, s2.turn, :assistant, response)

          // handle done before dispatching
          match action.type {
            :done => {
              val summary = action.args["summary"] /> ifNil("Task complete.")
              val s3 = s2 /> session.finish(summary)

              // auto-commit any file changes that were not explicitly committed
              val s4 = match hasUncommittedChanges(s3) {
                false => s3
                true  => {
                  val msg = buildCommitMessage(s3)
                  println("  auto-committing changes: " + msg)
                  defer onerror(err) {
                    println("  ⚠ auto-commit failed: " + err.msg)
                    s3
                  }
                  val result = gitRepo.commit(s3.repoRoot, msg)
                  println("  ✓ committed: " + result.sha)
                  session.addPatch(s3, "[commit]", "", result.sha, msg)
                }
              }

              store.saveSession(conn, id, s4)
              onDone(s4)
              s4
            }
            _ => {
              onToolStart(s2, action)
              val toolResult = dispatchTool(s2, action, valErr, ask)
              val lastPatch = match action.type == :edit && toolResult.ok {
                true => toolResult.session.patches[-1]
                false => nil
              }
              onToolResult(s2, action, toolResult, lastPatch)

              val resultMsg = format.formatResult({
                tool:   label(action.type),
                ok:     toolResult.ok,
                output: toolResult.output,
              })

              val s3 = toolResult.session
                /> session.addHistory(:user, resultMsg)

              // persist turn then updated session state
              store.appendTurn(conn, id, s3.turn, :user, resultMsg)
              store.saveSession(conn, id, s3)

              recur(conn, id, s3, slugSpec, manifest, mode, hooks)
            }
          }
        }
      }
    }
  }
}

// --- public entry points ---

@export
val loadPromptArtifacts = fn() {
  {
    slugSpec: loadSpec(SLUG_SPEC),
    manifest: loadSpec(MANIFEST),
  }
}

@export
val runHarness = fn(conn, id, s, slugSpec, manifest, mode = :local, hooks = {}) {
  runLoop(conn, id, s, slugSpec, manifest, mode, hooks)
}

/**
 * starts a new agent session for `goal` in `repoRoot`.
 *
 * Opens the database, runs migrations, creates the session record,
 * loads the Slug spec and manifest, then enters the loop.
 *
 * Returns the completed session.
 *
 * @effects('db fs net')
 */
@export
val run = fn(@str goal, @str repoRoot, mode = :local) {
  val conn     = store.openDb()
  defer { db.close(conn) }

  val artifacts = loadPromptArtifacts()
  val slugSpec = artifacts.slugSpec
  val manifest = artifacts.manifest

  val { id, session: s } = store.createSession(conn, goal, repoRoot)

  println("▶ Knuckles session " + id)
  println("  goal: " + goal)
  println("  repo: " + repoRoot)
  println("  mode: " + label(mode))
  println("")

  runLoop(conn, id, s, slugSpec, manifest, mode, {})
}

/**
 * resumes an existing session by ID.
 *
 * Loads the session from the database and re-enters the loop
 * from where it left off.
 *
 * Returns the completed session, or `nil` if the ID is not found.
 *
 * @effects('db fs net')
 */
@export
val resume = fn(@str id, mode = :local) {
  val conn = store.openDb()
  defer { db.close(conn) }

  val artifacts = loadPromptArtifacts()
  val slugSpec = artifacts.slugSpec
  val manifest = artifacts.manifest

  match store.loadSession(conn, id) {
    nil => {
      println("Session not found: " + id)
      nil
    }
    { session: s } => {
      match s.done {
        true => {
          println("Session " + id + " is already complete.")
          println(format.formatSummary(s))
          s
        }
        false => {
          println("▶ Resuming session " + id + " (turn " + s.turn + ")")
          println("  goal: " + s.goal)
          println("  mode: " + label(mode))
          println("")
          runLoop(conn, id, s, slugSpec, manifest, mode, {})
        }
      }
    }
  }
}
