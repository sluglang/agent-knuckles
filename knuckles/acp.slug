val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
)
val log     = import("slug.log").logger(moduleName())
val db      = import("slug.io.db")
val jsonrpc = import("slug.jsonrpc")
val runtime = import("slug.acp.runtime")
val acp     = import("slug.acp.types")
val agent   = import("knuckles.agent")
val store   = import("knuckles.store")
val session = import("knuckles.core.session")
val format  = import("knuckles.core.format")

val AGENT_NAME = "Knuckles"
val AGENT_VERSION = "0.1.0"
val PROTOCOL_VERSION = 1

val firstPromptText = fn(prompt) {
log.debug("p: {}", prompt)
  prompt
  /> ifNil([])
  /> find(fn(part) { part["type"] == "text" })
  /> ifNil({})
  /> fn(part) { part["text"] /> ifNil("") }
}

val detectMode = fn(goal, entry, currentSession) {
  val text = goal /> toLower
  match text /> containsAny("review", "report", "describe") {
    true => :report
    false => match currentSession.goal /> contains("issue #") {
      true => :issue
      false => entry["mode"] /> ifNil(:local)
    }
  }
}

val loadSessionOrThrow = fn(conn, sid) {
  match store.loadSession(conn, sid) {
    nil => throw Error {
      type: "JsonRpcError",
      code: jsonrpc.INVALID_PARAMS,
      msg: "unknown session",
      data: { sessionId: sid },
    }
    loaded => loaded
  }
}

@export
val handlers = fn() {
  {
    initialize: fn(ctx, params) {
      {
        protocolVersion: PROTOCOL_VERSION,
        agentInfo: {
          name: AGENT_NAME,
          version: AGENT_VERSION,
        },
        agentCapabilities: {
          sessions: {
            new: true,
            load: true,
          },
        },
      }
    },

    sessionNew: fn(ctx, params) {
      val sid = params["sessionId"] /> ifNil(randomHexString(16))
      val cwd = params["cwd"] /> ifNil(".")
      ctx.putSession(sid, {
        id: sid,
        cwd: cwd,
        mode: :local,
        knucklesId: nil,
        session: nil,
      })
      { sessionId: sid }
    },

    sessionLoad: fn(ctx, params) {
      val sid = params["sessionId"]
      val conn = store.openDb()
      defer { db.close(conn) }

      val loaded = loadSessionOrThrow(conn, sid)
      ctx.putSession(sid, {
        id: sid,
        cwd: loaded.session.repoRoot,
        mode: :local,
        knucklesId: sid,
        session: loaded.session,
      })
      { sessionId: sid }
    },

    sessionPrompt: fn(ctx, params) {
      val sid = params["sessionId"]
      val entry = ctx.getSession(sid)
      val prompt = params["prompt"] /> ifNil(params["content"] /> ifNil([]))
      val message = firstPromptText(prompt)

      val conn = store.openDb()
      defer { db.close(conn) }

      val createdOrLoaded = match entry["knucklesId"] {
        nil => {
          val created = store.createSession(
            conn,
            message,
            entry["cwd"] /> ifNil("."),
          )
          { knucklesId: created.id, session: created.session }
        }
        kid => {
          val baseSession = match entry["session"] {
            nil => loadSessionOrThrow(conn, kid).session
            s   => s
          }
          val nextSession = match message /> trim {
            "" => baseSession
            _  => {
              val s2 = baseSession /> session.addHistory(:user, message)
              store.appendTurn(conn, kid, s2.turn, :user, message)
              store.saveSession(conn, kid, s2)
              s2
            }
          }
          { knucklesId: kid, session: nextSession }
        }
      }

      val mode = detectMode(message, entry, createdOrLoaded.session)
      val artifacts = agent.loadPromptArtifacts()
      var activeToolCallId = nil

      val finalSession = agent.runHarness(
        conn,
        createdOrLoaded.knucklesId,
        createdOrLoaded.session,
        artifacts.slugSpec,
        artifacts.manifest,
        mode,
        {
          onTurn: fn(s, action) { nil },
          onThought: fn(s, thought, action) {
            match thought /> trim {
              "" => nil
              t  => ctx.sendAgentText(sid, t)
            }
          },
          onToolStart: fn(s, action) {
            val tid = label(action.type) + "-" + randomHexString(4)
            activeToolCallId = tid
            ctx.sendToolCall(sid, tid, label(action.type), action.args)
          },
          onToolResult: fn(s, action, toolResult, patch) {
            val tid = activeToolCallId /> ifNil(label(action.type) + "-" + randomHexString(4))
            activeToolCallId = nil
            val status = match toolResult.ok { true => "completed" false => "failed" }
            ctx.sendToolResultText(sid, tid, status, fmt("{}", toolResult.output))
          },
          onDone: fn(s) {
            ctx.sendAgentText(sid, format.formatSummary(s))
          },
          onLimit: fn(s, message) {
            ctx.sendAgentText(sid, message)
          },
          onModelNil: fn(s) {
            ctx.sendAgentText(sid, "Model returned no response. Retrying.")
          },
          ask: fn(question, s, action) {
            nil
          },
        },
      )

      ctx.putSession(sid, {
        id: sid,
        cwd: finalSession.repoRoot,
        mode: mode,
        knucklesId: createdOrLoaded.knucklesId,
        session: finalSession,
      })

      acp.endTurn()
    },
  }
}

@export
val serve = fn(io = nil) {
  runtime.run(handlers(), io)
}

@main
val main = fn() {
  serve()
}
