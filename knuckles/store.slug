/**
 * knuckles.store — session persistence
 *
 * Saves and loads agent sessions to a local SQLite database.
 * Uses `slug.db.migration` to ensure the schema is always current
 * and `slug.json` to serialise the full session state.
 *
 * ## Database location
 *
 * Controlled by `cfg("knuckles_db", "knuckles.db")`. Override via
 * config or the `--knuckles-db` CLI option.
 *
 * ## Schema
 *
 * The `kn_sessions` table stores one row per session. Scalar columns
 * (`goal`, `repo_root`, `turn`, `done`) are indexed for fast listing.
 * The full session state is stored as JSON in the `state` column and
 * round-trips through `slug.json#encode` / `slug.json#decode`.
 *
 * ## Session IDs
 *
 * IDs are 16-character random hex strings generated at creation time.
 * They are opaque — use `listSessions` to discover them.
 */

val {*} = import(
  "slug.std",
  "slug.string",
  "slug.list",
)
val db       = import("slug.io.db")
val json     = import("slug.json")
val migrate  = import("slug.db.migration")
val session  = import("knuckles.core.session")

val DB_PATH = cfg("knuckles_db", "knuckles.db")

// --- connection ---

/**
 * opens the Knuckles SQLite database and ensures the schema is current.
 *
 * Returns a connection handle. Always `defer db.close(conn)` after calling.
 *
 * @effects('db fs')
 */
@export
val openDb = fn() {
  val conn = db.connect("file:" + DB_PATH + "?cache=shared&mode=rwc", db.SQLITE_DRIVER)
  migrate.up(conn, base = "db/migrations")
  conn
}

// --- serialisation ---

// Removes ANSI escape sequences (\033[...m) from a string so that
// tool outputs containing terminal colour codes do not produce
// unescaped control characters when the session is JSON-encoded.
val stripAnsi = fn(@str s) {
  val esc = fromCodePoint(27)
  val step = fn(src, acc) {
    val i = src /> indexOf(esc)
    match i {
      -1 => acc + src
      _  => {
        val after = src[i + 1:]
        val end   = after /> indexOf("m")
        match end {
          -1 => acc + src[0:i]
          _  => recur(after[end + 1:], acc + src[0:i])
        }
      }
    }
  }
  step(s, "")
}

// Sanitises non-history session fields before JSON encoding.
// History is excluded from the state JSON entirely — it lives in kn_turns.
val sanitiseSession = fn(s) {
  val cleanResults = s.results /> map(fn(r) {
    r copy { output: stripAnsi(r.output) }
  })
  s copy { history: [], results: cleanResults }
}

val sessionToRow = fn(id, s) {
  val clean = sanitiseSession(s)
  {
    id:        id,
    goal:      clean.goal,
    repo_root: clean.repoRoot,
    turn:      clean.turn,
    done:      match clean.done { true => 1 false => 0 },
    summary:   clean.summary,
    state:     json.encode(clean),
  }
}

// Decodes a session row — history is populated separately via loadTurns.
val rowToSession = fn(row) {
  session.Session{} copy (json.decode(row["state"]))
}

// --- queries ---

val Q_INSERT = '''
  INSERT INTO kn_sessions (id, goal, repo_root, turn, done, summary, state)
  VALUES (:id, :goal, :repo_root, :turn, :done, :summary, :state)
'''

val Q_UPDATE = '''
  UPDATE kn_sessions
  SET turn       = :turn,
      done       = :done,
      summary    = :summary,
      state      = :state,
      updated_at = CURRENT_TIMESTAMP
  WHERE id = :id
'''

val Q_SELECT_BY_ID = '''
  SELECT * FROM kn_sessions WHERE id = :id
'''

val Q_SELECT_ALL = '''
  SELECT id, goal, repo_root, turn, done, summary, created_at, updated_at
  FROM kn_sessions
  ORDER BY created_at DESC
'''

val Q_SELECT_ACTIVE = '''
  SELECT id, goal, repo_root, turn, done, summary, created_at, updated_at
  FROM kn_sessions
  WHERE done = 0
  ORDER BY created_at DESC
'''

val Q_INSERT_TURN = '''
  INSERT INTO kn_turns (session_id, turn_num, role, content)
  VALUES (:session_id, :turn_num, :role, :content)
'''

val Q_SELECT_TURNS = '''
  SELECT role, content
  FROM kn_turns
  WHERE session_id = :session_id
  ORDER BY turn_num ASC, id ASC
'''

// --- public API ---

/**
 * creates a new session in the database and returns `{ id, session }`.
 *
 * The session ID is a 16-char random hex string. The session is saved
 * immediately so it exists in the DB from turn 0.
 *
 * @effects('db')
 */
@export
val createSession = fn(conn, @str goal, @str repoRoot) {
  val id = randomHexString(16)
  val s  = session.newSession(goal, repoRoot)
  val row = sessionToRow(id, s)
  db.exec(conn, Q_INSERT, row.id, row.goal, row.repo_root, row.turn, row.done, row.summary, row.state)
  { id: id, session: s }
}

/**
 * saves the current session state to the database.
 *
 * Called after every tool call to ensure crash recovery.
 *
 * @effects('db')
 */
@export
val saveSession = fn(conn, @str id, s) {
  val row = sessionToRow(id, s)
  db.exec(conn, Q_UPDATE, row.turn, row.done, row.summary, row.state, row.id)
  s
}

/**
 * appends a single conversation turn to `kn_turns`.
 *
 * Called by `agent.slug` immediately after each `addHistory` call so
 * that turns are persisted at the finest possible granularity — a crash
 * mid-session loses at most the current in-flight turn.
 *
 * `content` is ANSI-stripped before writing to avoid control characters
 * in the database.
 *
 * @effects('db')
 */
@export
val appendTurn = fn(conn, @str sessionId, @num turnNum, @sym role, @str content) {
  db.exec(conn, Q_INSERT_TURN, sessionId, turnNum, label(role), stripAnsi(content))
}

/**
 * loads all turns for a session as a list of `Turn` structs,
 * ordered by `turn_num` then insertion order.
 *
 * @effects('db')
 */
@export
val loadTurns = fn(conn, @str sessionId) {
  db.query(conn, Q_SELECT_TURNS, sessionId)
  /> map(fn(row) {
    session.Turn { role: sym(row["role"]), content: row["content"] }
  })
}

/**
 * loads a session by ID, hydrating `session.history` from `kn_turns`.
 *
 * Returns `{ id, session }` or `nil` if not found.
 * The returned session is identical in shape to one built in memory —
 * callers do not need to know that history comes from a separate table.
 *
 * @effects('db')
 */
@export
val loadSession = fn(conn, @str id) {
  db.query(conn, Q_SELECT_BY_ID, id)
  /> match {
    []    => nil
    [row] => {
      val s     = rowToSession(row)
      val turns = loadTurns(conn, id)
      { id: id, session: s copy { history: turns } }
    }
  }
}

/**
 * returns a list of all sessions as summary rows (no state JSON).
 *
 * Each row contains `id`, `goal`, `repo_root`, `turn`, `done`,
 * `summary`, `created_at`, `updated_at`.
 *
 * @effects('db')
 */
@export
val listSessions = fn(conn) {
  db.query(conn, Q_SELECT_ALL)
}

/**
 * returns a list of sessions that have not yet completed.
 *
 * @effects('db')
 */
@export
val listActiveSessions = fn(conn) {
  db.query(conn, Q_SELECT_ACTIVE)
}
